---
interface Props {
  name: string;
  title: string;
  tagline: string;
  ctaLabel: string;
  ctaHref: string;
}

const { name, title, tagline, ctaLabel, ctaHref } = Astro.props;
---

<section class="py-20 sm:py-28">
  <div class="mx-auto max-w-4xl px-4">
    <p class="text-sm font-medium tracking-widest uppercase text-[var(--color-accent)] mb-4">
      {title}
    </p>
    <h1 class="text-4xl sm:text-6xl font-bold text-[var(--color-text)] leading-tight mb-6">
      {name}
    </h1>
    <p class="text-lg sm:text-xl text-[var(--color-muted)] max-w-2xl mb-8 leading-relaxed">
      {tagline}
    </p>
    <a
      href={ctaHref}
      class="inline-flex items-center gap-2 rounded-lg bg-[var(--color-accent)] px-6 py-3 text-sm font-semibold text-white hover:opacity-90 transition-opacity"
    >
      {ctaLabel}
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </a>
  </div>
</section>
