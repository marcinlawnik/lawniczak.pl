---
import { execSync } from 'child_process';

const year = new Date().getFullYear();
const now = new Date();
const buildDate = now.toISOString().replace('T', ' ').slice(0, 16) + ' UTC';
const gitCommit = (() => {
  if (process.env.GIT_COMMIT && process.env.GIT_COMMIT !== 'unknown') {
    return process.env.GIT_COMMIT.slice(0, 7);
  }
  try {
    return execSync('git rev-parse --short HEAD').toString().trim();
  } catch {
    return 'unknown';
  }
})();
---

<footer class="border-t border-[var(--color-border)] py-8 mt-16">
  <div class="mx-auto max-w-4xl px-4 flex flex-col sm:flex-row items-center justify-between gap-4">
    <p class="text-sm text-[var(--color-muted)]">
      &copy; {year} Marcin Ławniczak
    </p>
    <p class="text-xs text-[var(--color-muted)] font-mono">
      {buildDate} &middot; <a href={`https://github.com/marcinlawnik/lawniczak.pl/commit/${gitCommit}`} target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-accent)] transition-colors">{gitCommit}</a>
