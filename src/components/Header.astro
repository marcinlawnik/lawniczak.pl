---
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  lang: 'en' | 'pl';
  currentPath: string;
}

const { lang, currentPath } = Astro.props;

// Explicit route map: en path → pl path
const routeMap: Record<string, string> = {
  '/': '/pl',
  '/projects': '/pl/projekty',
};
const reverseRouteMap = Object.fromEntries(Object.entries(routeMap).map(([en, pl]) => [pl, en]));

const enPath = reverseRouteMap[currentPath] ?? '/';
const plPath = routeMap[currentPath] ?? '/pl';

const navLinks =
  lang === 'en'
    ? [
        { href: '/', label: 'Home' },
        { href: '/projects', label: 'Projects' },
      ]
    : [
        { href: '/pl', label: 'Strona główna' },
        { href: '/pl/projekty', label: 'Projekty' },
      ];
---

<header class="sticky top-0 z-50 border-b border-[var(--color-border)] bg-[var(--color-bg)]/90 backdrop-blur">
  <nav class="mx-auto flex max-w-4xl items-center justify-between px-4 py-3">
    <a href={lang === 'en' ? '/' : '/pl'} class="font-semibold text-[var(--color-text)] hover:text-[var(--color-accent)] transition-colors">
      Marcin Ławniczak
    </a>

    <div class="flex items-center gap-4">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-sm text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors"
        >
          {link.label}
        </a>
      ))}

      <div class="flex items-center gap-2 border-l border-[var(--color-border)] pl-4">
        <a
          href={lang === 'en' ? plPath : enPath}
          class="text-xs font-medium uppercase tracking-wide text-[var(--color-muted)] hover:text-[var(--color-accent)] transition-colors"
          aria-label="Switch language"
        >
          {lang === 'en' ? 'PL' : 'EN'}
        </a>
        <ThemeToggle />
      </div>
    </div>
  </nav>
</header>
