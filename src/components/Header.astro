---
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  lang: 'en' | 'pl';
  currentPath: string;
}

const { lang, currentPath } = Astro.props;

// Explicit route map: pl path → en path
const routeMap: Record<string, string> = {
  '/': '/en',
  '/projekty': '/en/projects',
};
const reverseRouteMap = Object.fromEntries(Object.entries(routeMap).map(([pl, en]) => [en, pl]));

const enPath = routeMap[currentPath] ?? reverseRouteMap[currentPath] ?? '/en';
const plPath = reverseRouteMap[currentPath] ?? routeMap[currentPath] ?? '/';

const navLinks =
  lang === 'pl'
    ? [
        { href: '/', label: 'Strona główna' },
        { href: '/projekty', label: 'Projekty' },
      ]
    : [
        { href: '/en', label: 'Home' },
        { href: '/en/projects', label: 'Projects' },
      ];
---

<header class="sticky top-0 z-50 border-b border-[var(--color-border)] bg-[var(--color-bg)]/90 backdrop-blur">
  <nav class="mx-auto flex max-w-4xl items-center justify-between px-4 py-3">
    <a href={lang === 'pl' ? '/' : '/en'} class="font-semibold text-[var(--color-text)] hover:text-[var(--color-accent)] transition-colors">
      Marcin Ławniczak
    </a>

    <div class="flex items-center gap-4">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-sm text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors"
        >
          {link.label}
        </a>
      ))}

      <div class="flex items-center gap-2 border-l border-[var(--color-border)] pl-4">
        <a
          href={lang === 'pl' ? enPath : plPath}
          class="text-xs font-medium uppercase tracking-wide text-[var(--color-muted)] hover:text-[var(--color-accent)] transition-colors"
          aria-label="Switch language"
        >
          {lang === 'pl' ? 'EN' : 'PL'}
        </a>
        <ThemeToggle />
      </div>
    </div>
  </nav>
</header>
