---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Hero from '../../components/Hero.astro';
import About from '../../components/About.astro';
import { useTranslations } from '../../i18n/utils';

const lang = 'pl';
const t = useTranslations(lang);

const skills = [
  'TypeScript', 'PHP', 'Python', 'Node.js',
  'React', 'Astro', 'Docker', 'PostgreSQL',
  'Redis', 'Linux', 'Git',
];
---

<Base title={t('siteTitle')} description={t('siteDescription')} lang={lang}>
  <Header lang={lang} currentPath={Astro.url.pathname} />
  <main>
    <Hero
      name={t('heroName')}
      title={t('heroTitle')}
      tagline={t('heroTagline')}
      ctaLabel={t('heroCta')}
      ctaHref={t('heroCtaHref')}
    />
    <About
      heading={t('aboutHeading')}
      bio={t('aboutBio')}
      skillsLabel={t('aboutSkillsLabel')}
      skills={skills}
    />
  </main>
  <Footer />
</Base>
